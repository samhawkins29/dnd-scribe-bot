# ═══════════════════════════════════════════════════
#  D&D Scribe Bot — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════

# ─── Discord ──────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
# Optional: restrict slash commands to a specific server (faster registration)
DISCORD_GUILD_ID=

# ─── Anthropic (Claude) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=8192

# ─── Transcription Service ───────────────────────
# Options: whisper-local | assemblyai | deepgram
TRANSCRIPTION_SERVICE=whisper-local

# ─── Whisper (local, free) ───────────────────────
WHISPER_BINARY=whisper
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
# If using whisper.cpp, set the path to the .bin model file:
WHISPER_CPP_MODEL=

# ─── AssemblyAI (cloud, speaker diarization) ─────
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# ─── Deepgram (cloud, fast diarization) ──────────
DEEPGRAM_API_KEY=your_deepgram_key_here

# ─── Story Style ─────────────────────────────────
# Options: martin | sanderson
DEFAULT_STYLE=martin

# Story creativity level: strict | balanced | creative | transcript-only (default)
# transcript-only: narrates only transcript events, allows minor atmospheric transitions
# and character reactions but no invented scenes, characters, or dialogue
STORY_CREATIVITY=transcript-only

# ─── Cross-Session Learning ─────────────────────
# The bot automatically learns from verification results across sessions.
# After each story is verified, fabrications and omissions are saved to
# stories/verification-history.json. On subsequent runs, the last 5 sessions'
# patterns are analyzed and injected into the prompt so the model avoids
# repeating the same types of mistakes (e.g., inventing atmospheric details,
# misidentifying speakers). No configuration needed — this is automatic.

# ─── Recap Channel ───────────────────────────────
# Channel name to auto-post stories to (case-insensitive partial match)
RECAP_CHANNEL_NAME=recap

# ─── Audio ───────────────────────────────────────
# Options: ogg | pcm
AUDIO_FORMAT=ogg
FFMPEG_PATH=ffmpeg

# ─── Logging ─────────────────────────────────────
# Options: debug | info | warn | error
LOG_LEVEL=info
